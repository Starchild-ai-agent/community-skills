{
  "strategy_id": "rsi-reversal",
  "name": "RSI Reversal",
  "description": "Long oversold assets, short overbought assets using RSI thresholds",
  "category": "mean-reversion",
  "parameters": {
    "long_assets": ["BTC", "ETH", "WOO", "ZEC", "XMR"],
    "short_assets": ["ARB", "APT", "SUI", "OP", "AVAX", "NEAR", "ICP"],
    "rsi_period": 14,
    "timeframe": "1d",
    "long_entry": 40,
    "long_exit": 55,
    "short_entry": 60,
    "short_exit": 45,
    "leverage": 15,
    "max_positions": 8,
    "position_size_pct": 10,
    "allow_shorts": true,
    "cycle_interval": 24
  },
  "risk_management": {
    "stop_loss_pct": 5,
    "take_profit_pct": 25,
    "max_drawdown_pct": 10,
    "daily_loss_limit_pct": 2,
    "max_correlation": 0.7
  },
  "execution": {
    "order_type": "limit",
    "slippage_tolerance": 0.5,
    "min_liquidity_usd": 100000,
    "fill_timeout_seconds": 300
  }
}